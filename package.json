{
  "private": true,
  "name": "@automovie/station",
  "version": "0.1.0",
  "description": "automovie monorepo — LLM structured-output engine for character/object motion",
  "packageManager": "pnpm@10.6.4",
  "scripts": {
    "build": "pnpm --filter=./packages/** -r build",
    "test": "pnpm --filter @automovie/test build && pnpm --filter @automovie/test start",
    "e2e:tgz": "node internals/e2e-tgz.mjs",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\""
  },
  "keywords": [
    "llm",
    "function-calling",
    "structured-output",
    "animation",
    "motion",
    "typia"
  ],
  "author": "Samchon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/automovie"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "prettier": "^3.5.3",
    "prettier-plugin-jsdoc": "^1.3.2",
    "rimraf": "^6.0.1",
    "ttsc": "catalog:typescript",
    "@ttsc/lint": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
