{
  "name": "@automovie/mcp",
  "version": "0.1.0",
  "description": "automovie MCP server ??the deterministic film engine as Model Context Protocol tools",
  "main": "src/index.ts",
  "bin": {
    "automovie-mcp": "lib/bin.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && ttsc",
    "postbuild": "node ../../internals/config/assertBuild.js",
    "start": "ttsx src/bin.ts",
    "prepack": "pnpm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "typia", "llm", "animation"],
  "author": "Samchon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/automovie"
  },
  "files": ["lib", "src", "package.json", "LICENSE", "README.md"],
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
      "automovie-mcp": "lib/bin.js"
    }
  },
  "dependencies": {
    "@automovie/engine": "workspace:^",
    "@automovie/interface": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typia/mcp": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "rimraf": "^6.0.1",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
