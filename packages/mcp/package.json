{
  "name": "@automovie/mcp",
  "version": "0.1.0",
  "description": "automovie MCP server: deterministic motion-control engine as Model Context Protocol tools",
  "main": "src/index.ts",
  "bin": {
    "automovie-mcp": "lib/bin.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "pnpm run build:prompt",
    "build:prompt": "node build/prompt.mjs",
    "build": "pnpm run build:prompt && rimraf lib && ttsc && tsc --emitDeclarationOnly",
    "postbuild": "node ../../internals/config/assertBuild.js",
    "start": "ttsx src/bin.ts",
    "prepack": "pnpm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "typia", "llm", "animation"],
  "author": "Samchon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/automovie"
  },
  "files": ["lib", "src", "package.json", "LICENSE", "README.md"],
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
      "automovie-mcp": "lib/bin.js"
    },
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@automovie/engine": "workspace:^",
    "@automovie/interface": "workspace:^",
    "@automovie/render": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typia/mcp": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "rimraf": "^6.0.1",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
