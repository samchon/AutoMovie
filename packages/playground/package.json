{
  "private": true,
  "name": "@automovie/playground",
  "version": "0.1.0",
  "description": "automovie playground, a usable web UI: viewer viewport + humanoid character editor",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "ttsc --noEmit && ttsc -p tsconfig.scripts.json --noEmit && vite build",
    "build:human": "node scripts/build-human.mjs",
    "build:stickman": "node scripts/build-stickman.cjs",
    "build:cat": "node scripts/build-cat.cjs",
    "build:head": "node scripts/build-head-model.mjs",
    "build:horse": "node scripts/build-horse.cjs",
    "build:knight": "node scripts/build-knight.cjs",
    "build:models": "npm run build:stickman && npm run build:cat && npm run build:horse && npm run build:knight",
    "render:see": "node scripts/render-and-see.cjs",
    "render:sequence": "node scripts/render-sequence-and-see.cjs",
    "shots": "node scripts/capture-shots.mjs",
    "shots:head": "node scripts/capture-head.mjs",
    "preview": "vite preview --port 4173 --strictPort",
    "smoke:capture": "node scripts/capture-smoke.cjs"
  },
  "author": "Samchon",
  "license": "MIT",
  "dependencies": {
    "@automovie/engine": "workspace:^",
    "@automovie/forge": "workspace:^",
    "@automovie/interface": "workspace:^",
    "@automovie/render": "workspace:^",
    "@automovie/viewer": "workspace:^",
    "@pixiv/three-vrm": "catalog:three",
    "three": "catalog:three"
  },
  "devDependencies": {
    "@gltf-transform/core": "catalog:gltf",
    "@ttsc/unplugin": "catalog:typescript",
    "@types/node": "catalog:utils",
    "@types/pngjs": "catalog:media",
    "@types/three": "catalog:three",
    "esbuild": "catalog:vite",
    "gifenc": "catalog:media",
    "h264-mp4-encoder": "catalog:media",
    "playwright-core": "catalog:media",
    "pngjs": "catalog:media",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite",
    "@ttsc/lint": "catalog:typescript"
  }
}
