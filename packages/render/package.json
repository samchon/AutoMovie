{
  "name": "@automovie/render",
  "version": "0.1.0",
  "description": "automovie render — deterministic frame schedule + encode plan from a render spec",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && ttsc && tsc --emitDeclarationOnly",
    "postbuild": "node ../../internals/config/assertBuild.js",
    "prepack": "pnpm run build"
  },
  "author": "Samchon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/automovie"
  },
  "files": [
    "lib",
    "src",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@automovie/engine": "workspace:^",
    "@automovie/interface": "workspace:^",
    "@gltf-transform/core": "catalog:gltf"
  },
  "devDependencies": {
    "rimraf": "catalog:utils",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript",
    "@ttsc/lint": "catalog:typescript"
  }
}
